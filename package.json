{
	"name": "electron-remote",
	"version": "0.0.0",
	"private": true,
	"description": "electron remote monorepo setup",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"repository": {
		"type": "git",
		"url": "git@github.com:kavsingh/electron-remote"
	},
	"type": "module",
	"scripts": {
		"dev": "conc 'pnpm dev:ui' 'pnpm dev:electron'",
		"dev:ui": "docker compose up --watch app-ui",
		"dev:electron": "wait-on tcp:5321 && pnpm turbo run dev --filter app-electron",
		"lint": "turbo run lint",
		"test:e2e": "turbo run test:e2e --filter app-e2e",
		"build:mac": "turbo run build:mac --filter app-electron",
		"serve:ui-prod": "docker compose up app-ui-prod",
		"clean:turbo": "rimraf ./**/.turbo --glob"
	},
	"devDependencies": {
		"@eslint/core": "1.2.1",
		"@tsconfig/node24": "24.0.4",
		"@tsconfig/strictest": "2.0.8",
		"@types/node": "24.13.2",
		"@types/wait-on": "5.3.4",
		"@typescript/native-preview": "7.0.0-dev.20260628.1",
		"code-config": "workspace:*",
		"concurrently": "10.0.3",
		"cross-env": "10.1.0",
		"dotenv": "17.4.2",
		"lefthook": "2.1.9",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"oxlint-tsgolint": "catalog:",
		"rimraf": "6.1.3",
		"turbo": "2.10.0",
		"typescript": "npm:@typescript/typescript6@^6.0.1",
		"wait-on": "9.0.10"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
