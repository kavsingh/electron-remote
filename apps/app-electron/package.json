{
	"name": "app-electron",
	"version": "1.0.0-dev.0",
	"description": "an electron app with remote ui",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"type": "module",
	"main": "./bundle/electron/index.js",
	"scripts": {
		"prepare": "install-electron && install-app-deps",
		"dev": "vite dev",
		"build": "vite build",
		"start": "vite preview",
		"lint": "oxlint && oxfmt --check",
		"tdd": "vitest --reporter=verbose",
		"test": "vitest run",
		"test:ci": "vitest run --silent --coverage --reporter=dot",
		"build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.ts",
		"build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.ts",
		"build:win:x64": "pnpm run build && electron-builder --win --x64 --config electron-builder.config.ts",
		"build:win:arm64": "pnpm run build && electron-builder --win --arm64 --config electron-builder.config.ts"
	},
	"dependencies": {
		"electron-log": "catalog:",
		"superjson": "catalog:",
		"systeminformation": "5.31.14",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@app/ipc": "workspace:*",
		"@app/shared": "workspace:*",
		"@electron/fuses": "2.1.3",
		"@electron/notarize": "3.1.1",
		"@rolldown/plugin-babel": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"app-ui": "workspace:*",
		"electron": "catalog:",
		"electron-builder": "26.15.3",
		"immer": "catalog:",
		"jsdom": "catalog:",
		"memfs": "catalog:",
		"terser": "catalog:",
		"vite": "catalog:",
		"vite-plugin-bundle-obfuscator": "1.13.0",
		"vite-plugin-electron": "1.1.0",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24"
	},
	"productName": "Electron Remote"
}
