{
	"name": "electron-remote",
	"version": "0.0.0",
	"private": true,
	"description": "electron remote monorepo setup",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"repository": {
		"type": "git",
		"url": "git@github.com:kavsingh/electron-remote"
	},
	"type": "module",
	"scripts": {
		"dev": "conc 'pnpm dev:ui' 'pnpm dev:electron'",
		"dev:ui": "pnpm turbo run dev --filter app-ui",
		"dev:electron": "wait-on http://localhost:5321 && pnpm turbo run dev --filter app-electron",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"test:ci": "turbo run test:ci",
		"test:e2e": "turbo run test:e2e --filter app-e2e",
		"build:mac": "turbo run build:mac --filter app-electron",
		"serve:ui-prod": "docker compose up app-ui-prod",
		"clean:turbo": "rimraf ./**/.turbo --glob"
	},
	"devDependencies": {
		"@eslint/core": "1.2.1",
		"@tsconfig/node24": "24.0.4",
		"@tsconfig/strictest": "2.0.8",
		"@types/node": "24.13.2",
		"@types/wait-on": "5.3.4",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"code-config": "workspace:*",
		"concurrently": "10.0.3",
		"cross-env": "10.1.0",
		"dotenv": "17.4.2",
		"lefthook": "2.1.10",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"oxlint-tsgolint": "catalog:",
		"rimraf": "6.1.3",
		"turbo": "2.10.5",
		"typescript": "npm:@typescript/typescript6@6.0.2",
		"wait-on": "9.0.10"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
