{
	"name": "app-electron",
	"version": "1.0.0-dev.0",
	"description": "an electron app with remote ui",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"type": "module",
	"main": "./out/main/index.cjs",
	"scripts": {
		"prepare": "install-electron && install-app-deps",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"start": "electron-vite preview",
		"lint": "tsr generate && oxlint && oxfmt --check",
		"tdd": "vitest --reporter=verbose",
		"test": "vitest run",
		"test:ci": "vitest run --silent --coverage --reporter=dot",
		"build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.ts",
		"build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.ts",
		"build:win:x64": "pnpm run build && electron-builder --win --x64 --config electron-builder.config.ts",
		"build:win:arm64": "pnpm run build && electron-builder --win --arm64 --config electron-builder.config.ts"
	},
	"dependencies": {
		"electron-log": "catalog:",
		"superjson": "catalog:",
		"systeminformation": "5.31.7",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@electron/fuses": "2.1.2",
		"@electron/notarize": "3.1.1",
		"@playwright/test": "catalog:",
		"@rolldown/plugin-babel": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tanstack/devtools-vite": "catalog:",
		"@tanstack/eslint-plugin-router": "catalog:",
		"@tanstack/react-devtools": "catalog:",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-query-devtools": "catalog:",
		"@tanstack/react-router": "catalog:",
		"@tanstack/react-router-devtools": "catalog:",
		"@tanstack/router-cli": "catalog:",
		"@tanstack/router-plugin": "catalog:",
		"@testing-library/dom": "catalog:",
		"@testing-library/jest-dom": "catalog:",
		"@testing-library/react": "catalog:",
		"@testing-library/user-event": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"app-shared": "workspace:*",
		"babel-plugin-react-compiler": "catalog:",
		"design-system": "workspace:*",
		"electron": "catalog:",
		"electron-builder": "26.15.3",
		"electron-vite": "6.0.0-beta.1",
		"eslint-plugin-better-tailwindcss": "catalog:",
		"eslint-plugin-jest-dom": "catalog:",
		"eslint-plugin-playwright": "catalog:",
		"eslint-plugin-react-hooks": "catalog:",
		"eslint-plugin-testing-library": "catalog:",
		"immer": "catalog:",
		"jsdom": "catalog:",
		"memfs": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:",
		"tailwindcss": "catalog:",
		"terser": "catalog:",
		"vite": "catalog:",
		"vite-plugin-bundle-obfuscator": "1.12.0",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24"
	},
	"productName": "AppRemote"
}
