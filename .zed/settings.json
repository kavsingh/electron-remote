{
	"format_on_save": "on",
	"hard_tabs": true,
	"preferred_line_length": 84,
	"prettier": { "allowed": false },
	"formatter": [{ "language_server": { "name": "oxfmt" } }],
	"code_actions_on_format": { "source.fixAll.oxc": true },

	"lsp": {
		"tailwindcss-language-server": {
			"settings": {
				"validate": true,
				"classFunctions": ["twJoin", "twMerge", "tv"],
				"experimental": {
					"configFile": {
						"packages/design-system/index.css": "packages/design-system/components/**",
						"apps/app-frontend/src/index.css": "apps/app-frontend/src/**",
						"apps/app-electron/src/renderer/index.css": "apps/app-electron/src/renderer/**"
					}
				}
			}
		}
	},

	"languages": {
		"TypeScript": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			]
		},

		"TSX": {
			"language_servers": [
				"tsgo",
				"oxlint",
				"tailwindcss-language-server",
				"oxfmt"
			]
		},

		"JavaScript": { "language_servers": ["tsgo", "oxlint", "oxfmt"] },

		"CSS": {
			"language_servers": [
				"tailwindcss-intellisense-css",
				"tailwindcss-language-server",
				"oxfmt",
				"!vscode-css-language-server"
			]
		}
	}
}
