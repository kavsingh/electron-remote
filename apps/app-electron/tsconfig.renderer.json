{
	"$schema": "https://json.schemastore.org/tsconfig",
	"include": [
		"./src/common",
		"./src/renderer",
		"./src/vitest.renderer.setup.ts",
		"../../packages/design-system/layouts/page.tsx"
	],
	"extends": "code-config/tsconfig.browser.json",
	"compilerOptions": {
		"composite": true,
		"emitDeclarationOnly": true,
		"jsx": "react-jsx",
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"~/*": ["./src/renderer/*"],
			"~common/*": ["./src/common/*"]
		},
		"types": ["vite/client"]
	}
}
